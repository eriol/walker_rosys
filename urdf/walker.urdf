<?xml version="1.0"?>
<robot name="walker_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="$(find walker_rosys)/urdf/imu.urdf.xacro" />
  <xacro:include filename="$(find walker_rosys)/urdf/hokuyo.urdf.xacro" />
  <xacro:include filename="$(find walker_rosys)/urdf/d435_camera.urdf.xacro" />
  <xacro:include filename="$(find walker_rosys)/urdf/odrive_ros2_control.xacro" />

  <xacro:arg name="sensors_pose_file" default="$(find walker_rosys)/config/sensors_pose.yaml" />
  <xacro:property name="sensors_pose_file" value="$(arg sensors_pose_file)" />
  <xacro:property name="camera_front_left"
    value="${xacro.load_yaml(sensors_pose_file)['camera_front_left']}" />
  <xacro:property name="camera_front_right"
    value="${xacro.load_yaml(sensors_pose_file)['camera_front_right']}" />
  <xacro:property name="camera_back" value="${xacro.load_yaml(sensors_pose_file)['camera_back']}" />
  <xacro:property name="imu" value="${xacro.load_yaml(sensors_pose_file)['imu']}" />
  <xacro:property name="lidar" value="${xacro.load_yaml(sensors_pose_file)['lidar']}" />

  <xacro:property name="degree30" value="0.52" />
  <xacro:property name="degree45" value="0.79" />
  <xacro:property name="degree60" value="1.05" />
  <xacro:property name="degree90" value="1.57" />
  <xacro:property name="degree180" value="3.14" />

  <xacro:property name="base_width" value="0.58" />
  <xacro:property name="base_length" value="0.58" />
  <xacro:property name="base_height" value="0.9" />
  <xacro:property name="frame" value="0.015" />

  <xacro:property name="wheel_radius" value="0.17" />
  <xacro:property name="wheel_width" value="0.02" />

  <xacro:property name="wheel_ygap" value="0.025" />
  <xacro:property name="wheel_zoff" value="0.01" />
  <xacro:property name="wheel_xoff" value="0.05" />


  <!-- - - - - -  Define intertial property macros - - - - - -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}" />
      <mass value="${m}" />
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0" iyy="${(m/12) * (w*w + d*d)}"
        iyz="0.0" izz="${(m/12) * (w*w + h*h)}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
      <mass value="${m}" />
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0" ixz="0" iyy="${(m/12) * (3*r*r + h*h)}"
        iyz="0" izz="${(m/2) * (r*r)}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}" />
      <inertia ixx="${(2/5) * m * (r*r)}" ixy="0.0" ixz="0.0" iyy="${(2/5) * m * (r*r)}" iyz="0.0"
        izz="${(2/5) * m * (r*r)}" />
    </inertial>
  </xacro:macro>


  <!-- - - - - - Robot Base - - - - - -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 -0.07" rpy="0 0 0" />
      <geometry>
        <mesh filename="$(find walker_rosys)/meshes/walker_frame.dae" />
      </geometry>
      <material name="Cyan">
        <color rgba="0 1.0 1.0 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.07" rpy="0 0 0" />
      <geometry>
        <mesh filename="$(find walker_rosys)/meshes/walker_frame.dae" />
      </geometry>
    </collision>

    <xacro:box_inertia m="5" w="${base_width}" d="${base_length}" h="${base_height}" />
  </link>

  <xacro:if value="$(arg enable_gazebo_plugin)">
    <gazebo reference="base_link">
      <material>Gazebo/Orange</material>
    </gazebo>
  </xacro:if>

  <!-- - - - - - Caster Wheel - - - - - -->
  <link name="caster">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
      <geometry>
        <sphere radius="${wheel_zoff}" />
      </geometry>
      <material name="white">
        <color rgba="1 1.0 1.0 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
      <geometry>
        <sphere radius="${wheel_zoff}" />
      </geometry>
    </collision>

    <xacro:sphere_inertia m="0.5" r="${(wheel_radius+wheel_zoff-(base_height/2))}" />
  </link>

  <xacro:if value="$(arg enable_gazebo_plugin)">
    <gazebo reference="caster">
      <material>Gazebo/Blue</material>
      <mu1 value="0.0" />
      <mu2 value="0.0" />
      <kp value="10000000.0" />
      <kd value="1.0" />
      <turnGravityOff>false</turnGravityOff>
    </gazebo>
  </xacro:if>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link" />
    <child link="caster" />
    <origin xyz="${base_length/2} 0 -0.07" rpy="0 0 0" />
  </joint>


  <!-- - - - - - Wheels - - - - - -->
  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        <geometry>
          <mesh filename="$(find walker_rosys)/meshes/wheel.dae" scale="1 1 0.3" />
        </geometry>
        <material name="Gray">
          <color rgba="0.5 0.5 0.5 1.0" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        <geometry>
          <mesh filename="$(find walker_rosys)/meshes/wheel.dae" scale="1 1 0.3" />
        </geometry>
      </collision>

      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_width}" />
    </link>

    <joint name="${prefix}_joint" type="continuous">
      <parent link="base_link" />
      <child link="${prefix}_link" />
      <origin xyz="${-(base_length+frame)/2} ${y_reflect*(base_width/2-wheel_width)} ${frame}"
        rpy="0 0 0" />
      <axis xyz="0 1 0" />
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="drivewhl_l" x_reflect="-1" y_reflect="1" />
  <xacro:wheel prefix="drivewhl_r" x_reflect="-1" y_reflect="-1" />

  <xacro:unless value="$(arg enable_gazebo_plugin)">
    <!-- ODrive ROS2 Control -->
    <xacro:odrive_ros2_control
      name="ODriveDiffBot"
      joint0_name="drivewhl_l_joint"
      joint1_name="drivewhl_r_joint" />
  </xacro:unless>

  <!-- - - - - - Gazebo Plugin - - - - - -->
  <xacro:if value="$(arg enable_gazebo_plugin)">
    <gazebo>
      <plugin name='diff_drive' filename='libgazebo_ros_diff_drive.so'>

        <!-- wheels -->
        <left_joint>drivewhl_l_joint</left_joint>
        <right_joint>drivewhl_r_joint</right_joint>

        <!-- kinematics -->
        <wheel_separation>0.65</wheel_separation>
        <wheel_diameter>0.18</wheel_diameter>

        <!-- limits -->
        <max_wheel_torque>80</max_wheel_torque>
        <max_wheel_acceleration>1.0</max_wheel_acceleration>

        <!-- output -->
        <publish_odom>true</publish_odom>
        <publish_odom_tf>false</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>

        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>
      </plugin>
    </gazebo>
  </xacro:if>

  <!-- - - - - - Imu link and plugin - - - - - -->
  <xacro:imu_sensor xyz="${imu['xoff']} ${imu['yoff']} ${imu['zoff']}"
    rpy="${imu['roll']} ${imu['pitch']} ${imu['yaw']}"
    parent="base_link">
  </xacro:imu_sensor>

  <!-- - - - - - Laser link and plugin - - - - - -->
  <xacro:hokuyo_laser xyz="${lidar['xoff']} ${lidar['yoff']} ${lidar['zoff']}"
    rpy="${lidar['roll']} ${lidar['pitch']} ${lidar['yaw']}"
    parent="base_link">
  </xacro:hokuyo_laser>

  <!-- - - - - - Stereo Camera Front Left - - - - - -->
  <!-- <xacro:d435_camera xyz="${camera_front_left['xoff']} ${camera_front_left['yoff']}
  ${camera_front_left['zoff']}"
                rpy="${camera_front_left['roll']} ${camera_front_left['pitch']} ${camera_front_left['yaw']}"
                color="${camera_front_left['color']}"
                parent="base_link"
                camera_name="stereo_camera_front_left">
  </xacro:d435_camera>  -->

  <!-- - - - - - Stereo Camera Front Right - - - - - -->
  <!-- <xacro:d435_camera xyz="${camera_front_right['xoff']} ${camera_front_right['yoff']}
  ${camera_front_right['zoff']}" 
                rpy="${camera_front_right['roll']} ${camera_front_right['pitch']} ${camera_front_right['yaw']}"
                color="${camera_front_right['color']}"
                parent="base_link"
                camera_name="stereo_camera_front_right">
  </xacro:d435_camera>  -->

  <!-- - - - - - Stereo Camera Back - - - - - -->
  <!-- <xacro:d435_camera xyz="${camera_back['xoff']} ${camera_back['yoff']} ${camera_back['zoff']}" 
                rpy="${camera_back['roll']} ${camera_back['pitch']} ${camera_back['yaw']}"
                color="${camera_back['color']}"
                parent="base_link"
                camera_name="stereo_camera_back">
  </xacro:d435_camera>  -->


</robot>